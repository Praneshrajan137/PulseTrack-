# .env.example — Environment variable template for status-tracker v2.1
# ================================================================
# SETUP INSTRUCTIONS:
#   cp .env.example .env
#   Edit .env and fill in real values.
#   NEVER commit .env — .gitignore prevents this, but verify with git check-ignore.
# ================================================================

# ── REQUIRED FOR AUTHENTICATED OPERATION ──────────────────────────────────────
# Your Atlassian Statuspage webhook signing secret.
# How to obtain it:
#   1. Visit https://status.openai.com
#   2. Click "Subscribe to Updates" → "Webhook"
#   3. Enter your webhook URL and submit
#   4. Copy the "Signing secret" displayed after registration
# Generate a secure local test secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=your_atlassian_statuspage_webhook_secret_here

# ── PRODUCTION MODE ENFORCEMENT ───────────────────────────────────────────────
# Set to "true" in production to enforce WEBHOOK_SECRET at startup.
# If PRODUCTION_MODE=true and WEBHOOK_SECRET is absent, the service refuses
# to start, surfacing the misconfiguration immediately rather than running
# silently without authentication.
# Leave as "false" (or unset) for local development.
PRODUCTION_MODE=false

# ── LOG LEVEL ─────────────────────────────────────────────────────────────────
# DEBUG   : verbose — includes HMAC trace, dedup discards, filter decisions
# INFO    : status events and startup messages (recommended for production)
# WARNING : warnings and errors only
# ERROR   : errors only
# NOTE: load_dotenv() in main.py MUST be called before logging.basicConfig()
#       for this setting to take effect. The code enforces this ordering.
LOG_LEVEL=INFO

# ── SERVER CONFIGURATION ──────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── COMPONENT FILTER ──────────────────────────────────────────────────────────
# Comma-separated list of keywords for component name filtering.
# Matching is case-insensitive substring: "api" matches "OpenAI API - Chat Completions".
# Leave empty (or omit entirely) to use the hardcoded default list in processor.py.
# HTTP 202 is ALWAYS returned to Atlassian regardless of this filter —
# non-matching components are acknowledged but not logged to console.
# Examples:
#   MONITORED_KEYWORDS=api,chat completions,embeddings
#   MONITORED_KEYWORDS=chat completions,realtime
MONITORED_KEYWORDS=

# ── KEY ROTATION (USE ONLY DURING ACTIVE ROTATION WINDOW) ─────────────────────
# Enable by switching security.py Depends() to verify_hmac_signature_dual_key().
# Remove after rotation completes (revert to verify_hmac_signature single-key).
# WEBHOOK_SECRET_PRIMARY=new_key_registered_with_atlassian
# WEBHOOK_SECRET_SECONDARY=old_key_still_active_on_atlassian_edge_nodes
